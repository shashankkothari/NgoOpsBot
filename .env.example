# =============================================================================
# NGO OpsBot — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
ENV=development                           # development | production
DEBUG=true                                # Set false in production
SECRET_KEY=change-me-to-a-random-64-char-hex-string
ALLOWED_HOSTS=localhost,127.0.0.1

# Base URL where this app is publicly reachable (no trailing slash)
# Used for Telegram webhook registration
APP_BASE_URL=https://your-app.up.railway.app

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
# asyncpg DSN — use postgresql+asyncpg:// scheme for SQLAlchemy async
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/ngoopsbot

# For Alembic (sync driver used only during migrations)
SYNC_DATABASE_URL=postgresql+psycopg2://postgres:password@localhost:5432/ngoopsbot

# Connection pool settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=20

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# Leave empty to disable Sentry in development
LOG_LEVEL=INFO                            # DEBUG | INFO | WARNING | ERROR

# -----------------------------------------------------------------------------
# Security & Encryption
# -----------------------------------------------------------------------------
# Fernet symmetric key for encrypting NGO Telegram bot tokens stored in DB.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-key-here

# NOT USED AT RUNTIME — each NGO's webhook secret is generated automatically
# (secrets.token_hex(32)) and stored encrypted in the ngos.webhook_secret column.
# The secret is embedded in the webhook URL path: /api/v1/webhook/{slug}/{secret}
# You do not need to set this variable; it is kept here only for historical reference.
# WEBHOOK_SECRET=

# API key that protects admin-only REST endpoints
ADMIN_API_KEY=change-me-to-a-random-api-key

# -----------------------------------------------------------------------------
# AI — Anthropic Claude
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL=claude-opus-4-5          # Default model for agent tasks
ANTHROPIC_MAX_TOKENS=4096

# -----------------------------------------------------------------------------
# AI — OpenAI (Whisper voice transcription)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-proj-...
WHISPER_MODEL=whisper-1

# -----------------------------------------------------------------------------
# Communications — SendGrid (email)
# -----------------------------------------------------------------------------
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@yourngodomain.org
SENDGRID_FROM_NAME=NGO OpsBot

# -----------------------------------------------------------------------------
# Communications — MSG91 (SMS / WhatsApp)
# -----------------------------------------------------------------------------
MSG91_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxx
MSG91_SENDER_ID=NGOBОТ
MSG91_TEMPLATE_ID=your-approved-template-id   # DLT template ID (India)
MSG91_BASE_URL=https://api.msg91.com/api/v5

# -----------------------------------------------------------------------------
# Google APIs (Google Workspace / Drive / Calendar / Sheets integration)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxx
# Comma-separated OAuth scopes
GOOGLE_SCOPES=https://www.googleapis.com/auth/spreadsheets,https://www.googleapis.com/auth/drive.readonly,https://www.googleapis.com/auth/calendar.readonly
# Redirect URI registered in Google Cloud Console
GOOGLE_REDIRECT_URI=https://your-app.up.railway.app/api/v1/integrations/google/callback

# -----------------------------------------------------------------------------
# Scheduler (APScheduler)
# -----------------------------------------------------------------------------
SCHEDULER_TIMEZONE=UTC
SCHEDULER_MAX_INSTANCES=3

# -----------------------------------------------------------------------------
# Rate limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_PER_MINUTE=60                  # Per-tenant Telegram message rate limit
