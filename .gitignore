# =============================================================================
# NGO OpsBot — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Environment & secrets
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.p12
secrets/
credentials.json
service_account.json
token.json

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.installed.cfg
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
MANIFEST

# Virtual environments
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
.python-version

# Type checking & linting
.mypy_cache/
.ruff_cache/
.dmypy.json
dmypy.json

# Testing & coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
*.py,cover
nosetests.xml
test-results/

# -----------------------------------------------------------------------------
# Node / Next.js (dashboard)
# -----------------------------------------------------------------------------
dashboard/node_modules/
dashboard/.next/
dashboard/out/
dashboard/.env
dashboard/.env.local
dashboard/.env.development.local
dashboard/.env.test.local
dashboard/.env.production.local
dashboard/npm-debug.log*
dashboard/yarn-debug.log*
dashboard/yarn-error.log*
dashboard/.pnpm-debug.log*

# -----------------------------------------------------------------------------
# Alembic
# -----------------------------------------------------------------------------
# Keep versions tracked; ignore pycache inside
alembic/__pycache__/
alembic/versions/__pycache__/

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
.dockerignore

# -----------------------------------------------------------------------------
# Railway
# -----------------------------------------------------------------------------
.railway/

# -----------------------------------------------------------------------------
# IDEs & editors
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Logs & temp files
# -----------------------------------------------------------------------------
*.log
logs/
tmp/
temp/
*.tmp

# -----------------------------------------------------------------------------
# Uploads / media (store in object storage, not git)
# -----------------------------------------------------------------------------
uploads/
media/

# -----------------------------------------------------------------------------
# Jupyter (if used for data analysis)
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.bak
*.orig
htmlcov/
